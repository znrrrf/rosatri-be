generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// IMPORTANT:
// 1. Add `CREATE EXTENSION IF NOT EXISTS "pgcrypto";` to the first migration SQL.
// 2. Add the partial index `idx_active_bookings` manually in migration SQL.
// 3. `email` and `username` are modeled with `@unique`; extra duplicate indexes are omitted.

enum UserRole {
  Admin  @map("admin")
  Owner  @map("owner")
  Renter @map("renter")

  @@map("user_role_enum")
}

enum BookingStatus {
  Pending   @map("pending")
  Active    @map("active")
  Cancelled @map("cancelled")
  Finished  @map("finished")

  @@map("booking_status_enum")
}

enum InvoiceStatus {
  Unpaid  @map("unpaid")
  Paid    @map("paid")
  Late    @map("late")
  Partial @map("partial")

  @@map("invoice_status_enum")
}

enum PaymentMethod {
  Cash     @map("cash")
  Transfer @map("transfer")
  Ewallet  @map("ewallet")

  @@map("payment_method_enum")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName     String    @map("first_name") @db.VarChar(255)
  lastName      String?   @map("last_name") @db.VarChar(255)
  username      String    @unique @db.VarChar(255)
  email         String    @unique @db.VarChar(255)
  passwordHash  String    @map("password_hash") @db.Text
  phone         String?   @db.VarChar(50)
  address       String?   @db.Text
  idCardNumber  String?   @map("id_card_number") @db.VarChar(100)
  idCardPhoto   String?   @map("id_card_photo") @db.VarChar(255)
  role          UserRole
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  ownedKos      Kos[]     @relation("UserOwnedKos")
  renterBookings Booking[] @relation("UserBookings")

  @@map("users")
}

model Kos {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId   String    @map("owner_id") @db.Uuid
  kosName   String    @map("kos_name") @db.VarChar(255)
  location  String?   @db.Text
  lat       Decimal?  @db.Decimal(10, 7)
  lng       Decimal?  @db.Decimal(10, 7)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  owner     User      @relation("UserOwnedKos", fields: [ownerId], references: [id], onDelete: Cascade)
  rooms     Room[]

  @@index([ownerId], map: "idx_kos_owner")
  @@map("kos")
}

model Room {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kosId     String    @map("kos_id") @db.Uuid
  roomName  String    @map("room_name") @db.VarChar(100)
  roomType  String?   @map("room_type") @db.VarChar(100)
  price     Decimal   @db.Decimal(12, 2)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  kos       Kos       @relation(fields: [kosId], references: [id], onDelete: Cascade)
  bookings  Booking[]

  @@index([kosId], map: "idx_rooms_kos")
  @@map("rooms")
}

model Booking {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId     String        @map("room_id") @db.Uuid
  renterId   String        @map("renter_id") @db.Uuid
  startDate  DateTime      @map("start_date") @db.Date
  endDate    DateTime?     @map("end_date") @db.Date
  status     BookingStatus @default(Pending)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  room       Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  renter     User          @relation("UserBookings", fields: [renterId], references: [id], onDelete: Cascade)
  invoices   Invoice[]

  @@index([roomId], map: "idx_bookings_room")
  @@index([renterId], map: "idx_bookings_renter")
  @@index([status], map: "idx_bookings_status")
  @@map("bookings")
}

model Invoice {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId    String        @map("booking_id") @db.Uuid
  billingMonth DateTime      @map("billing_month") @db.Date
  amount       Decimal       @db.Decimal(12, 2)
  dueDate      DateTime      @map("due_date") @db.Date
  status       InvoiceStatus @default(Unpaid)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  booking      Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@index([bookingId], map: "idx_invoices_booking")
  @@index([status], map: "idx_invoices_status")
  @@index([dueDate], map: "idx_invoices_due_date")
  @@map("invoices")
}

model Payment {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId     String         @map("invoice_id") @db.Uuid
  amount        Decimal        @db.Decimal(12, 2)
  paymentDate   DateTime       @map("payment_date") @db.Timestamp(6)
  paymentMethod PaymentMethod? @map("payment_method")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  invoice       Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId], map: "idx_payments_invoice")
  @@index([paymentDate], map: "idx_payments_date")
  @@map("payments")
}