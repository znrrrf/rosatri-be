{
  "name": "rosatri-backend",
  "version": "1.0.0",
  "main": "src/server.ts",
  "scripts": {
    "test": "node --import tsx tests/run-tests.ts",
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prisma:format": "npx prisma format",
    "prisma:validate": "npx prisma validate",
    "prisma:migrate:create": "npx prisma migrate dev --create-only",
    "prisma:migrate:dev": "npx prisma migrate dev",
    "prisma:migrate:deploy": "npx prisma migrate deploy",
    "prisma:migrate:status": "npx prisma migrate status"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Backend API setup for Rosatri boarding house",
  "type": "module",
  "private": true,
  "dependencies": {
    "@types/nodemailer": "^7.0.11",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prisma": "^7.4.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
